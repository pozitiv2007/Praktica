<Window x:Class="StudentAppWPF.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление администраторами" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Администраторы" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <DataGrid x:Name="UsersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#f9f9f9" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                <DataGridTemplateColumn Header="Действия" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑️" Width="30" Click="DeleteUser_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" BorderBrush="#ccc" BorderThickness="1" Padding="10" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Добавить администратора" FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <TextBox x:Name="NewLoginBox" Width="150" Margin="0,0,10,0" ToolTip="Логин"/>
                    <PasswordBox x:Name="NewPasswordBox" Width="150" Margin="0,0,10,0" ToolTip="Пароль"/>
                    <Button x:Name="AddButton" Content="Добавить" Width="100" Click="AddButton_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
